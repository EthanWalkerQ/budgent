# --- Budgent backend config ---
NODE_ENV=development
PORT=8787

# Postgres + Redis
DATABASE_URL=postgresql://USER@localhost:5432/budgent?schema=public
REDIS_URL=redis://localhost:6379

# Solana mainnet via Helius
HELIUS_API_KEY=your-helius-key
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-key
WS_URL=wss://mainnet.helius-rpc.com/?api-key=your-helius-key
COMMITMENT=confirmed

# Deployed program
PROGRAM_ID=H9nJ3SKkXExHCqs56jaFsVvRajTFzTyNqjmZLWqeV7yM

# Keys (encrypted-at-rest keystore dir + master secret for delegate keys)
KEYSTORE_DIR=../.keys
KEYSTORE_SECRET=change-me-32-bytes-hex
OWNER_KEYPAIR=../.keys/owner.json

# Enforcement behaviour:
#  true  = submit policy-violating intents on-chain so the NETWORK reverts them
#          (real failed tx with the program error; costs only the base fee ~5000 lamports)
#  false = reject violations off-chain without submitting
ENFORCE_ONCHAIN_REVERTS=true

# Optional: bootstrap admin token for owner/admin endpoints (Bearer)
ADMIN_TOKEN=change-me
